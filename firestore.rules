rules_version = '2';

// Coverstory Firestore security rules.
//
// Deploy with the Firebase CLI:  firebase deploy --only firestore:rules
// (or paste into Firebase Console → Firestore Database → Rules).
//
// Model:
//   - Every user owns exactly one profile document at users/{uid}.
//   - Their generated excuses live in the users/{uid}/excuses subcollection.
//   - A user may only ever read/write their OWN data (uid must match the
//     authenticated user). Nothing is world-readable.
//   - The /admin collection is reserved for a single hardcoded admin UID
//     (future admin panel). Replace the placeholder before using it.
//   - Any path not matched below is denied by default (Firestore denies
//     everything that isn't explicitly allowed), so no other collection is
//     exposed.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's own profile document — read/write only when signed in as that user.
    match /users/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;

      // A user's own saved excuses — same ownership check.
      match /excuses/{excuseId} {
        allow read, write: if request.auth != null
          && request.auth.uid == uid;
      }
    }

    // Admin-only area (future admin panel). Locked to a single admin UID.
    // TODO: replace "YOUR_ADMIN_UID" with the real admin's Firebase Auth UID
    // (Firebase Console → Authentication → Users → copy the User UID).
    match /admin/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == "YOUR_ADMIN_UID";
    }
  }
}
